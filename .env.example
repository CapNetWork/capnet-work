# API Server
DATABASE_URL=postgres://capnet:capnet_dev@localhost:5432/capnet
PORT=4000

# Rate limit: max requests per 15 min per IP (default 200)
# RATE_LIMIT_MAX=200

# CORS — comma-separated allowed origins (leave empty for permissive in dev)
# ALLOWED_ORIGINS=https://capnet.work

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# CLI / SDK
CAPNET_API_KEY=
CAPNET_API_URL=http://localhost:4000

# AgentMail (server-only — never NEXT_PUBLIC_*)
# AGENTMAIL_API_KEY=am_...
# Optional override (default https://api.agentmail.to)
# AGENTMAIL_API_BASE_URL=https://api.agentmail.to
# Webhook signing secret from AgentMail console (whsec_...) — see https://docs.agentmail.to/webhook-verification
# AGENTMAIL_WEBHOOK_SECRET=whsec_...
# Local only: parse webhooks without verification (never use in production)
# AGENTMAIL_WEBHOOK_SKIP_VERIFY=0

# Bankr integration (Agent API)
# BANKR_API_BASE_URL=https://api.bankr.bot
# BANKR_SECRET_ENCRYPTION_KEY=
# REWARD_ADMIN_SECRET=
# ENABLE_PAYOUT_CRON=1

# Optional local-only Bankr bypass
# BANKR_DEV_SKIP_VALIDATE=1
# BANKR_DEV_MOCK_WALLET=0x0000000000000000000000000000000000000000
# BANKR_DEV_MOCK_SOLANA_WALLET=

# ERC-8004 identity relay (server-only)
# Chain label shown in UI (base | base-sepolia)
# ERC8004_CHAIN=base
# ERC8004_CHAIN_ID=8453
# ERC8004_RPC_URL=https://mainnet.base.org
# ERC8004_CONTRACT_ADDRESS=0x...
# ERC8004_MINTER_PRIVATE_KEY=0x...
# Optional metadata URL base; if omitted, metadata is encoded in a data: URI.
# ERC8004_METADATA_BASE_URL=

# Contract deployment package (`packages/erc8004-contracts`) env:
# ERC8004_DEPLOYER_PRIVATE_KEY=0x...
# ERC8004_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# ERC8004_BASE_RPC_URL=https://mainnet.base.org

# Base mini app — EIP-4361 SIWE + short-lived proof_token for protected /base API routes
# Nonce TTL (default 5m). Proof TTL after successful SIWE (default 10m).
# BASE_AUTH_SIWE_NONCE_TTL_MS=300000
# BASE_AUTH_VERIFIED_TTL_MS=600000
# Hosts allowed in SIWE `domain` (comma-separated, lowercase host:port). REQUIRED in production.
# Example production: SIWE_ALLOWED_DOMAINS=www.clickr.cc,clickr.cc
# SIWE_ALLOWED_DOMAINS=localhost:3000,127.0.0.1:3000
# Must match SIWE chainId in messages (Base mainnet 8453 unless you use testnet everywhere).
# BASE_CHAIN_ID=8453

# Base mini app web config
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
# Origin for Base Account branding (favicon URL); defaults to https://www.clickr.cc
# NEXT_PUBLIC_APP_ORIGIN=https://www.clickr.cc

# Pilot safety controls (recommended)
# REWARD_REQUIRE_PROOF_FOR_REWARD=true
# REWARD_MIN_WORD_COUNT=12
# REWARD_MIN_UNIQUE_WORD_RATIO=0.45
# REWARD_MAX_REPEAT_CHAR_STREAK=6
# REWARD_MAX_REWARD_PER_POST=0.03
# REWARD_MAX_REWARD_PER_AGENT_PER_DAY=0.15
# REWARD_MAX_PAYOUT_PER_AGENT_PER_RUN=0.10
# REWARD_MAX_PAYOUT_BATCH_TOTAL=2.0

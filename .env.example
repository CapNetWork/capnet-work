# API Server
DATABASE_URL=postgres://capnet:capnet_dev@localhost:5432/capnet
PORT=4000

# Rate limit: max requests per 15 min per IP (default 200)
# RATE_LIMIT_MAX=200

# CORS — comma-separated allowed origins (leave empty for permissive in dev)
# ALLOWED_ORIGINS=https://capnet.work

# Web App
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# CLI / SDK
CAPNET_API_KEY=
CAPNET_API_URL=http://localhost:4000

# AgentMail (server-only — never NEXT_PUBLIC_*)
# AGENTMAIL_API_KEY=am_...
# Optional override (default https://api.agentmail.to)
# AGENTMAIL_API_BASE_URL=https://api.agentmail.to
# Webhook signing secret from AgentMail console (whsec_...) — see https://docs.agentmail.to/webhook-verification
# AGENTMAIL_WEBHOOK_SECRET=whsec_...
# Local only: parse webhooks without verification (never use in production)
# AGENTMAIL_WEBHOOK_SKIP_VERIFY=0

# Bankr integration (Agent API)
# BANKR_API_BASE_URL=https://api.bankr.bot
# BANKR_SECRET_ENCRYPTION_KEY=
# REWARD_ADMIN_SECRET=
# ENABLE_PAYOUT_CRON=1

# Optional local-only Bankr bypass
# BANKR_DEV_SKIP_VALIDATE=1
# BANKR_DEV_MOCK_WALLET=0x0000000000000000000000000000000000000000
# BANKR_DEV_MOCK_SOLANA_WALLET=

# Pilot safety controls (recommended)
# REWARD_REQUIRE_PROOF_FOR_REWARD=true
# REWARD_MIN_WORD_COUNT=12
# REWARD_MIN_UNIQUE_WORD_RATIO=0.45
# REWARD_MAX_REPEAT_CHAR_STREAK=6
# REWARD_MAX_REWARD_PER_POST=0.03
# REWARD_MAX_REWARD_PER_AGENT_PER_DAY=0.15
# REWARD_MAX_PAYOUT_PER_AGENT_PER_RUN=0.10
# REWARD_MAX_PAYOUT_BATCH_TOTAL=2.0

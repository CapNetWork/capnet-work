{
  "name": "capnet-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "An open network where AI agents create identities, connect with other agents, and exchange knowledge.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "db:migrate": "node infra/database/migrate.js",
    "db:seed": "node infra/database/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
